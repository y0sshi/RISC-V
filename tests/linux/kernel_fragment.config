# Config fragment merged on top of `make ARCH=riscv defconfig` for the boot sim.
# Goal: smallest reliable path to the earlycon banner + userspace on rv_soc.

# --- Console: earlycon=sbi (earliest, always works via OpenSBI) + 8250 (ttyS0) ---
CONFIG_SERIAL_EARLYCON=y
CONFIG_RISCV_SBI=y
# earlycon=sbi on Linux 6.x needs either the SBI DBCN extension (OpenSBI >= 1.3)
# or the legacy v0.1 console putchar.  We boot OpenSBI v1.2 (no DBCN), so V01 is
# REQUIRED -- without it early_sbi_setup() returns -ENODEV and no banner appears.
# CONFIG_HVC_RISCV_SBI also depends on this.
CONFIG_RISCV_SBI_V01=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_OF_PLATFORM=y
CONFIG_HVC_RISCV_SBI=y
CONFIG_PRINTK=y
CONFIG_PRINTK_TIME=y

# --- Built-in initramfs (the static /init); embedded in the Image ---
CONFIG_BLK_DEV_INITRD=y
# gen_init_cpio listing file (declares /dev/console + /init); see build.sh.
CONFIG_INITRAMFS_SOURCE="/workspace/tests/linux/work/initramfs.list"
CONFIG_RD_GZIP=y

# --- Trim things we cannot/need not exercise in the early-boot sim ---
# (kept conservative: defconfig already boots; these only speed build/boot)
CONFIG_RISCV_ISA_ZICBOM=n
CONFIG_RISCV_ISA_V=n
# SMP off: single hart core; avoids secondary-hart bring-up wait.
CONFIG_SMP=n

# Networking off: real-HW bring-up hangs in inet_init -> netlink_table_grab
# (PID1 blocks forever in schedule(); sim boots through it fine -- a real-HW-only
# atomic/LR-SC/memory-ordering divergence under real DDR timing).  The userspace
# milestone (static /init: write()+idle) needs no networking, so disabling the
# whole net stack skips inet_init and isolates that hang from the boot path.
CONFIG_NET=n

