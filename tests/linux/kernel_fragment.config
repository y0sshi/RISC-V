# Config fragment merged on top of `make ARCH=riscv defconfig` for the boot sim.
# Goal: smallest reliable path to the earlycon banner + userspace on rv_soc.

# --- Console: earlycon=sbi (earliest, always works via OpenSBI) + 8250 (ttyS0) ---
CONFIG_SERIAL_EARLYCON=y
CONFIG_RISCV_SBI=y
# earlycon=sbi on Linux 6.x needs either the SBI DBCN extension (OpenSBI >= 1.3)
# or the legacy v0.1 console putchar.  We boot OpenSBI v1.2 (no DBCN), so V01 is
# REQUIRED -- without it early_sbi_setup() returns -ENODEV and no banner appears.
# CONFIG_HVC_RISCV_SBI also depends on this.
CONFIG_RISCV_SBI_V01=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_OF_PLATFORM=y
CONFIG_HVC_RISCV_SBI=y
CONFIG_PRINTK=y
CONFIG_PRINTK_TIME=y

# --- Built-in initramfs; embedded in the Image ---
CONFIG_BLK_DEV_INITRD=y
# CONFIG_INITRAMFS_SOURCE is supplied per-build by build.sh (work/gen_initramfs.config):
#   ROOTFS=minimal   -> gen_init_cpio listing (static /init)
#   ROOTFS=buildroot -> Buildroot rootfs.cpio (glibc + bash)
CONFIG_RD_GZIP=y

# --- glibc rootfs needs an auto-populated /dev (Buildroot busybox relies on it) ---
# devtmpfs auto-mounted at boot so /dev/console, /dev/ttyS0, ... exist before
# busybox init runs.  Harmless for the minimal rootfs (which ships its own nodes).
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# --- Trim things we cannot/need not exercise in the early-boot sim ---
# (kept conservative: defconfig already boots; these only speed build/boot)
CONFIG_RISCV_ISA_ZICBOM=n
CONFIG_RISCV_ISA_V=n
# SMP off: single hart core; avoids secondary-hart bring-up wait.
CONFIG_SMP=n

# Networking: NET=y (defconfig default).  The real-HW netlink hang that once
# forced NET=n is FIXED (2026-06-19).  Root cause was an RTL AMO write-loss
# (rv_soc.sv:364: core_dmem_wait was masked to 0 by an instruction-fetch PTW, so
# an amoadd.w retired before its write committed -> atomic_dec on nl_table_users
# was lost -> netlink_table_grab spun forever).  After the fix, real HW reaches
# userspace with CONFIG_NET=y across consecutive boots (nl_table_users settles to
# 0 every time; verify with boards/zybo_z720/vitis/verify_nety_us.tcl).  See
# memory zybo-netlink-atomic-bug and src/software/boot/ptw_amo_test.S (regression).
# To fall back to NET=n for a faster userspace milestone, uncomment below + rebuild
# with FORCE_KERNEL=1.
# CONFIG_NET=n

